PORT=3000
# Store backend: "insforge" (default) or "memory".
# Demo default is "memory" (rehearsed, zero deps). Switch to "insforge" only
# after the live verify step in DAYOF-RUNBOOK.md passes.
STORE=memory

# Nebius Token Factory (OpenAI-compatible). NOTE: rebranded from "AI Studio" —
# base URL is api.tokenfactory.nebius.com (verified from docs 2026-06-19).
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1
# Pick a FAST instruct model from `GET {base}/models` (runbook step 2). Avoid
# reasoning models (DeepSeek-R1 etc — slow/verbose for our JSON). Heads-up:
# a "Model Deprecation Jun 22" notice is live, so confirm the slug isn't sunset.
# Candidates to try: meta-llama/Llama-3.3-70B-Instruct, Qwen/Qwen2.5-72B-Instruct,
# deepseek-ai/DeepSeek-V3-0324.
NEBIUS_MODEL=

# Insforge. BASE_URL = project host root, NO trailing /api (store.js appends
# /api/database/records/<table>). Create the table first (runbook step 3).
INSFORGE_BASE_URL=
INSFORGE_API_KEY=
INSFORGE_TABLE=calls

# Vapi (public key is browser-safe; injected into the page at /api/config)
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=
